<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Login - POS</title>
  <link rel="stylesheet" href="/style.css" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <style>
    :root{
      --bg:#f4f7fb;
      --card:#ffffff;
      --text:#0f172a;
      --muted:#64748b;
      --line:#e5eaf2;
      --primary:#2563eb;
      --primary2:#60a5fa;
      --shadow: 0 14px 40px rgba(15,23,42,.10);
      --radius: 16px;
      --danger:#b91c1c;
      --dangerBg:#fee2e2;
    }

    *{box-sizing:border-box}

    body{
      margin:0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      color:var(--text);
      background:var(--bg);
      min-height:100vh;
      display:flex;
      flex-direction:column;
    }

    .site{
      width:100%;
      max-width: 920px;
      margin: 0 auto;
      padding: 32px 20px 48px;
      flex:1;
    }

    /* HEADER */
    .app-header{
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      width:100%;
      max-width:860px;
      margin:0 auto;
      padding: 22px 28px;
      box-shadow: 0 8px 22px rgba(15,23,42,.06);
      display:flex;
      justify-content:center;
      align-items:center;
      gap: 16px;
    }

    .app-header::before{ display:none; }

    .brand{
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .brand img{ height:98px; width:auto; object-fit:contain; display:block; }

    .title-wrap{
      text-align:left;
      line-height:1.05;
    }
    .header-title{
      font-size: 30px;
      font-weight: 1000;
      margin:0;
    }
    .header-subtitle{
      margin-top: 6px;
      font-size: 14px;
      font-weight: 900;
      font-style: italic;
    }

    .stack{
      margin-top: 22px;
      display:flex;
      flex-direction:column;
      gap: 16px;
    }

    .card{
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 34px;
    }

    /* LOGIN LANDSCAPE */
    .login-card{
      width:min(100%, 580px);
      max-width:580px;
      margin:0 auto;
    }

    .login-head{
      grid-column: 1 / -1;
    }

    .greeting{
      color:var(--muted);
      font-size: 13px;
      font-weight: 900;
      margin-bottom: 6px;
    }

    .login-head h2{
      margin: 0;
      font-size: 28px;
      font-weight: 1000;
    }

    .subtitle{
      color:var(--muted);
      margin-top: 6px;
      font-size: 15px;
    }

    .error{
      margin-top: 10px;
      background: var(--dangerBg);
      color: var(--danger);
      padding: 10px 12px;
      border-radius: 12px;
      font-size: 13px;
      font-weight: 900;
      border: 1px solid rgba(185,28,28,.2);
    }

    label{
      display:block;
      font-size: 12px;
      font-weight: 900;
      margin-bottom: 6px;
    }

    /* CLEAN INPUTS */
    input{
      width:100%;
      padding: 15px 16px;
      border-radius: 12px;
      border: 1px solid var(--line);
      font-size: 15px;
      background: #f8fafc;
      outline:none;
      transition: .2s ease;
    }

    input:focus{
      border-color: rgba(37,99,235,.55);
      box-shadow: 0 0 0 4px rgba(37,99,235,.10);
      background: #fff;
    }

    .field{ position:relative; }

    /* ✅ PRO EYE BUTTON (fixed positioning) */
    .toggle{
      position:absolute;
      right: 10px;
      top: 70%;
      transform: translateY(-50%);
      border:none;
      background: transparent;
      cursor:pointer;
      color: #64748b;
      padding: 6px;
      border-radius: 8px;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .toggle:hover{ background:#f1f5f9; }

    /* ✅ make form a grid so username/password sit side-by-side */
.login-form{
  grid-column: 1 / -1;
  display:grid;
  grid-template-columns: 1fr;
  gap: 18px;
}
    .login-form .meta-row,
    .login-form .actions{
      grid-column: 1 / -1;
    }

    .meta-row{
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-top: 6px;
    }

    .remember{
      display:flex;
      align-items:center;
      gap:8px;
      font-size: 13px;
      font-weight: 900;
      color: var(--muted);
      white-space: nowrap;
    }

    .help-link{
      text-decoration:none;
      color: var(--primary);
      font-weight: 900;
      font-size: 13px;
    }

    .actions{
      display:flex;
      gap:10px;
      margin-top: 8px;
    }

    /* ✅ single centered button */
    .actions.single{ justify-content:center; }
    .actions.single .btn-primary{ max-width:none; width: 100%; }

    button{
      flex:1;
      border-radius: 12px;
      padding: 15px 18px;
      font-weight: 1000;
      font-size: 14px;
      border: 1px solid var(--line);
      background:#fff;
      cursor:pointer;
    }

    .btn-primary{
      border:none;
      color:white;
      background: linear-gradient(135deg, #1d4ed8, #3b82f6);
      box-shadow: 0 10px 20px rgba(37,99,235,.18);
    }

    .footer-note{
      grid-column: 1 / -1;
      text-align:center;
      font-size: 12px;
      font-weight: 900;
      color: var(--muted);
      margin-top: 6px;
    }

    /* REPORTS DROPDOWN */
    .reports-dropdown{
      position: relative;
      display: flex;
      justify-content: center;
      margin-top: 14px;
      margin-bottom: 6px;
    }

    .reports-btn{
      background: linear-gradient(135deg, #1d4ed8, #3b82f6);
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 12px;
      font-weight: 900;
      font-size: 15px;
      cursor: pointer;
      box-shadow: 0 10px 20px rgba(37,99,235,.18);
    }

    .reports-menu{
      display: none;
      position: absolute;
      top: 110%;
      background: white;
      border: 1px solid #e5eaf2;
      border-radius: 12px;
      box-shadow: 0 14px 40px rgba(15,23,42,.12);
      overflow: hidden;
      min-width: 200px;
      z-index: 50;
    }

    .reports-menu a{
      display: block;
      padding: 12px 16px;
      text-decoration: none;
      color: #0f172a;
      font-weight: 700;
    }

    .reports-menu a:hover{
      background: #f1f5f9;
    }

    /* COPYRIGHT FOOTER */
    .copyright{
      text-align:center;
      padding: 14px 10px;
      font-size: 13px;
      font-weight: 900;
      color: var(--muted);
    }

    @media (max-width: 980px){
      .app-header{
        flex-direction:column;
        text-align:center;
        padding:18px;
      }
      .title-wrap{ text-align:center; }
      .login-card{ grid-template-columns: 1fr; }
      .login-form{ grid-template-columns: 1fr; }
    }

    @media (max-width: 560px){
      .site{ padding:18px 12px 32px; }
      .brand img{ height:76px; }
      .header-title{ font-size:24px; }
      .card{ padding:22px; }
      .meta-row{
        align-items:flex-start;
        flex-direction:column;
        gap:10px;
      }
    }
  </style>
</head>

<body>
  <div class="site">

    <header class="app-header">
      <div class="brand">
        <img src="/assets/logo-ss-png.png" alt="San Stephano Resort" />
      </div>

      <div class="title-wrap">
        <div class="header-title">San Stephano Resort</div>
        <div class="header-subtitle">Daily Access</div>
      </div>
    </header>

    <div class="stack">

      <!-- LOGIN -->
      <div class="card login-card">
        <div class="login-head">
          <div class="greeting" id="greeting2">Welcome</div>
          <h2>Welcome back</h2>
          <div class="subtitle">Please sign in to continue to your dashboard.</div>

          <% if (error) { %>
            <div class="error"><%= error %></div>
          <% } %>
        </div>

<form method="POST" action="/login" class="login-form">

  <div>
<label>Email</label>
<input id="email" name="email" placeholder="Enter your email" required />
  </div>

  <div class="field">
    <label>Password</label>
    <input id="password" type="password" name="password" placeholder="Enter your password" required />
    <button class="toggle" type="button" id="togglePw" aria-label="Show password">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"
              stroke="currentColor" stroke-width="2"/>
        <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
      </svg>
    </button>
  </div>

  <div class="meta-row">
    <label class="remember">
      <input type="checkbox" name="remember" />
      Remember me
    </label>
    <a class="help-link" href="#" onclick="alert('Connect reset-password flow'); return false;">Forgot password?</a>
  </div>

  <div class="actions single">
    <button type="submit" class="btn-primary">Continue</button>
  </div>

</form>

<div class="footer-note">Secure system - Contact IT if you need help</div>
      </div>
    </div>
  </div>
<script>
    // Greeting text
    const h = new Date().getHours();
    const text = h < 12 ? "Good morning" : (h < 18 ? "Good afternoon" : "Good evening");
    document.getElementById("greeting2").textContent = text;

    // Eye toggle for password (professional SVG)
    const pw = document.getElementById("password");
    const toggle = document.getElementById("togglePw");

    const eyeSvg = `
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"
              stroke="currentColor" stroke-width="2"/>
        <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
      </svg>`;

    const eyeOffSvg = `
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 3l18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M2 12s3.5-7 10-7c2 0 3.8.6 5.3 1.6M22 12s-3.5 7-10 7c-2 0-3.8-.6-5.3-1.6"
              stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>`;

    toggle.addEventListener("click", () => {
      const hidden = pw.type === "password";
      pw.type = hidden ? "text" : "password";
      toggle.innerHTML = hidden ? eyeOffSvg : eyeSvg;
      toggle.setAttribute("aria-label", hidden ? "Hide password" : "Show password");
    });

    // Reports dropdown
    function toggleReports(){
      const menu = document.getElementById("reportsMenu");
      menu.style.display = menu.style.display === "block" ? "none" : "block";
    }

    // Close dropdown if user clicks outside
    document.addEventListener("click", (e) => {
      const menu = document.getElementById("reportsMenu");
      const wrap = document.querySelector(".reports-dropdown");
      if (!wrap || !menu) return;
      if (!wrap.contains(e.target)) menu.style.display = "none";
    });
  </script>
  <%- include('partials/footer') %>
</body>
</html>
