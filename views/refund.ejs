<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || "Void / Refund Invoice" %></title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
<div class="site">

  <header class="app-header">
    <div class="app-title">Void / Refund Invoice</div>
    <div class="app-actions">
      <a class="btn logout-btn" href="/pos">POS</a>
      <% if (user && user.role === 'ADMIN') { %>
        <a class="btn logout-btn" href="/admin">Admin</a>
      <% } %>
    </div>
  </header>

  <div class="card" style="margin-top:18px;">
    <% const inv = (typeof invoice !== 'undefined' && invoice) ? invoice : ''; %>

    <% if (message) { %>
      <p style="color:#b91c1c; font-weight:800;"><%= message %></p>
    <% } %>

    <form method="GET" action="/refund" style="display:flex; gap:10px; align-items:end; flex-wrap:wrap;">
      <div style="max-width:260px;">
        <label style="font-weight:900; display:block; margin-bottom:6px;">Invoice Number</label>
<input
  type="number"
  name="invoice"
  placeholder="e.g. 120"
  value="%= typeof inv === 'string' ? inv : '' %>"
/>
      </div>

      <button class="btn primary" type="submit">Search</button>
      <a class="btn" href="/refund">Clear</a>
    </form>

    <% if (found) { %>
      <div style="margin-top:16px; border-top:1px solid #e5eaf2; padding-top:14px;">
        <div style="font-weight:900; margin-bottom:8px;">Invoice Found</div>

        <div class="badge <%= found.status === 'CONFIRMED' ? 'on' : 'off' %>">
          Status: <%= found.status %>
        </div>

        <div style="margin-top:10px;">
          <div>Invoice #: <%= found.invoiceNumber != null ? found.invoiceNumber : '-' %></div>
          <div><b>Confirmed At:</b> <%= found.confirmedAt ? formatBusinessDateTime(found.confirmedAt) : '-' %></div>
<% const displayTotal =
  found.total != null ? Number(found.total) :
  found.totalCents != null ? Number(found.totalCents) / 100 :
  found.finalTotalCents != null ? Number(found.finalTotalCents) / 100 :
  0;
%>

<div>Total: $<%= displayTotal.toFixed(2) %></div>        </div>

        <% if (found.status !== 'CONFIRMED') { %>
          <div class="muted" style="margin-top:10px; font-weight:800;">
            This invoice is not CONFIRMED, so it can’t be voided.
          </div>
        <% } else { %>
          <form method="POST" action="/refund/void" style="margin-top:14px; display:grid; gap:10px; max-width:520px;">
            <input type="hidden" name="orderId" value="<%= found.id %>" />

            <label>
              <div style="font-weight:900; margin-bottom:6px;">Reason</div>
              <input name="reason" placeholder="Reason for void/refund..." required />
            </label>

            <button
              class="btn danger"
              type="submit"
              onclick="return confirm('Are you sure you want to VOID this invoice? This will be logged.');">
              Void Invoice
            </button>

            <div class="muted" style="font-size:12px;">
              Tip: Only CONFIRMED invoices can be voided. Voided invoices stay in reports but marked as VOIDED.
            </div>
          </form>
        <% } %>
      </div>
    <% } else if (inv) { %>
      <div class="muted" style="margin-top:14px; font-weight:800;">
        No invoice loaded yet. If you searched and got nothing, it means the invoice number wasn’t found.
      </div>
    <% } %>

  </div>

</div>

<%- include('partials/footer') %>

<% if ((typeof autoPrintVoid !== 'undefined' && autoPrintVoid) && found) { %>
<script>
  const RECEIPT_PRINT_COUNT_KEY = 'cabine_pos_receipt_print_counts_v1';
  const RECEIPT_TIME_ZONE = '<%= businessTimeZone || "Asia/Beirut" %>';

  function formatReceiptDate(dateValue) {
    return new Intl.DateTimeFormat('en-GB', {
      timeZone: RECEIPT_TIME_ZONE,
      year: 'numeric',
      month: '2-digit',
      day: '2-digit'
    }).format(new Date(dateValue));
  }

  function formatReceiptTime(dateValue) {
    return new Intl.DateTimeFormat('en-GB', {
      timeZone: RECEIPT_TIME_ZONE,
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: true
    }).format(new Date(dateValue));
  }

  function nextReceiptPrintCount(invoiceNo, kind) {
    try {
      const raw = localStorage.getItem(RECEIPT_PRINT_COUNT_KEY);
      const map = raw ? JSON.parse(raw) : {};
      const key = `${kind || 'sale'}:${invoiceNo || 'N/A'}`;
      const next = Number(map[key] || 0) + 1;
      map[key] = next;
      localStorage.setItem(RECEIPT_PRINT_COUNT_KEY, JSON.stringify(map));
      return next;
    } catch (err) {
      console.error('Failed to store receipt print count:', err);
      return 1;
    }
  }

  function printHtmlInHiddenFrame(title, html) {
    const frame = document.createElement('iframe');
    frame.setAttribute('title', title);
    frame.style.position = 'fixed';
    frame.style.width = '0';
    frame.style.height = '0';
    frame.style.border = '0';
    frame.style.opacity = '0';
    frame.style.pointerEvents = 'none';
    frame.style.right = '0';
    frame.style.bottom = '0';
    document.body.appendChild(frame);

    const frameWindow = frame.contentWindow;
    const frameDocument = frameWindow.document;

    frameDocument.open();
    frameDocument.write(html);
    frameDocument.close();

    setTimeout(function () {
      try {
        frameWindow.focus();
        frameWindow.print();
      } finally {
        setTimeout(function () {
          frame.remove();
        }, 1500);
      }
    }, 500);
  }

  function printVoidedReceipt(order, reason) {
    const now = new Date();
    const printableItems = Array.isArray(order.items) && order.items.length
      ? order.items
      : Array.isArray(order.lines)
      ? order.lines.map(function (line) {
          return {
            qty: line.qty,
            price:
              line.price != null
                ? line.price
                : line.unitPriceCents != null
                ? Number(line.unitPriceCents) / 100
                : 0,
            total:
              line.total != null
                ? line.total
                : line.totalCents != null
                ? Number(line.totalCents) / 100
                : 0,
            category:
              line.category ||
              line.itemName ||
              line.service?.name ||
              line.product?.name ||
              line.Product?.name ||
              line.posItem?.name ||
              line.name ||
              'Item'
          };
        })
      : [];
    const invoiceNo = order && order.invoiceNumber != null
      ? String(order.invoiceNumber).padStart(6, '0')
      : 'N/A';
    const printCount = nextReceiptPrintCount(invoiceNo, 'void');

    const itemsHtml = printableItems.map(function (i) {
      const qty = Number(i.qty || 0);
      const lineTotal = Number(
        i.total != null ? i.total : (Number(i.price || 0) * qty)
      );

      return `
        <div class="row">
          <span>${i.category || 'Item'} x${qty}</span>
          <span>$${lineTotal.toFixed(2)}</span>
        </div>
      `;
    }).join('');

    const subtotal = Number(
      order.subtotal != null
        ? order.subtotal
        : printableItems.reduce(function (sum, item) {
            return sum + Number(item.qty || 0) * Number(item.price || 0);
          }, 0)
    );
    const discountAmount = Number(order.discountAmount || 0);
    const finalTotal = Number(
      order.total != null
        ? order.total
        : order.totalCents != null
        ? Number(order.totalCents) / 100
        : Math.max(0, subtotal - discountAmount)
    );

    printHtmlInHiddenFrame('Voided Receipt', `
      <html>
        <head>
          <title>Voided Receipt</title>
          <style>
            @page { size: 80mm auto; margin: 0; }
            body {
              margin: 0;
              padding: 8px;
              font-family: Arial, sans-serif;
              color: #000;
              width: 72mm;
              font-size: 12px;
            }
            .center { text-align: center; }
            .bold { font-weight: 700; }
            .big { font-size: 18px; font-weight: 800; }
            .line { border-top: 1px dashed #000; margin: 8px 0; }
            .row {
              display: flex;
              justify-content: space-between;
              gap: 8px;
              margin: 5px 0;
            }
            .header-title {
              text-align: center;
              font-weight: 700;
              font-size: 14px;
              margin-bottom: 6px;
            }
            .void-box {
              border: 3px solid #000;
              background: #f2f2f2;
              padding: 8px 6px;
              margin: 10px 0 6px;
              text-align: center;
              font-size: 20px;
              font-weight: 900;
              letter-spacing: 2px;
            }
            .void-stamp {
              border: 3px dashed #000;
              padding: 7px 6px;
              margin: 0 0 12px;
              text-align: center;
              font-size: 17px;
              font-weight: 900;
              letter-spacing: 3px;
            }
            .cut-space { height: 24px; }
          </style>
        </head>
        <body>
          <div class="center bold">San Stephano Daily Access</div>
          <div class="void-box">VOIDED</div>
          <div class="void-stamp">VOIDED INVOICE</div>

          <div class="row">
            <span>Invoice #</span>
            <span class="bold">${invoiceNo}</span>
          </div>

          <div class="row">
            <span>Status</span>
            <span class="bold">${order.status || 'VOIDED'}</span>
          </div>

          <div class="row">
            <span>Date</span>
            <span class="bold">${formatReceiptDate(now)}</span>
          </div>

          <div class="row">
            <span>Time</span>
            <span class="bold">${formatReceiptTime(now)}</span>
          </div>

          <div class="row">
            <span>Voided By</span>
            <span class="bold">${order.voidedByName || '-'}</span>
          </div>

          <div class="line"></div>

          ${itemsHtml || '<div class="center">No items found</div>'}

          <div class="line"></div>

          <div class="line"></div>

          <div class="row">
            <span>Subtotal</span>
            <span class="bold">$${subtotal.toFixed(2)}</span>
          </div>

          <div class="row">
            <span>Discount</span>
            <span class="bold">-$${discountAmount.toFixed(2)}</span>
          </div>

          <div class="row">
            <span>Total</span>
            <span class="bold">$${finalTotal.toFixed(2)}</span>
          </div>

          <div class="line"></div>

          <div class="center bold">VOID REASON</div>
          <div class="center">${reason || 'No reason provided'}</div>

          <div class="line"></div>

          <div class="center big">THIS INVOICE IS VOIDED</div>
          <div class="center small">Print #${printCount}</div>
          <div class="cut-space"></div>
        </body>
      </html>
    `);
  }
</script>

<script type="application/json" id="voided-order-data"><%- JSON.stringify(found) %></script>
<script type="application/json" id="void-reason-data"><%- JSON.stringify((typeof voidReason !== 'undefined' && voidReason) ? voidReason : '') %></script>

<script>
  const voidedOrder = JSON.parse(document.getElementById('voided-order-data').textContent);
  const voidReasonValue = JSON.parse(document.getElementById('void-reason-data').textContent);

  window.addEventListener('load', function () {
    printVoidedReceipt(voidedOrder, voidReasonValue);
  });
</script>
<% } %>

</body>
</html>
