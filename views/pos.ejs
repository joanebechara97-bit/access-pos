async function closeDay() {
  try {
    const statsRes = await fetch('/api/stats/my-daily-sales', {
      method: 'GET',
      headers: { 'Accept': 'application/json' }
    });

    const statsData = await statsRes.json();

    if (!statsRes.ok) {
      throw new Error(statsData.error || 'Failed to load daily stats');
    }

    const closeRes = await fetch('/api/session/close', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });

    const closeData = await closeRes.json();

    if (!closeRes.ok) {
      throw new Error(closeData.error || 'Failed to close day');
    }

    printDailySalesReport(statsData, function () {
      setTimeout(function () {
        window.location.reload();
      }, 300);
    });
  } catch (err) {
    console.error('closeDay error:', err);
    alert(err.message || 'Failed to close day');
  }
}
function reprintLastReceipt() {
  if (!lastConfirmedOrder || !lastConfirmedCart) {
    const stored = loadLastReceipt();

    if (!stored || !stored.order || !stored.cart) {
      alert('No receipt to reprint yet');
      return;
    }
  }

  printReceipt(
    lastConfirmedCart,
    lastConfirmedOrder,
    lastConfirmedDiscount || { value: 0, type: 'fixed', amount: 0 }
  );
}
function saveLastReceipt(cartData, orderData, discountData) {
  const payload = {
    cart: cartData,
    order: orderData,
    discount: discountData || { value: 0, type: 'fixed', amount: 0 }
  };

  localStorage.setItem(LAST_RECEIPT_KEY, JSON.stringify(payload));

  lastConfirmedCart = cartData;
  lastConfirmedOrder = orderData;
  lastConfirmedDiscount = discountData || { value: 0, type: 'fixed', amount: 0 };
}

function loadLastReceipt() {
  try {
    const raw = localStorage.getItem(LAST_RECEIPT_KEY);
    if (!raw) return null;

    const parsed = JSON.parse(raw);

    lastConfirmedCart = parsed.cart || null;
    lastConfirmedOrder = parsed.order || null;
    lastConfirmedDiscount = parsed.discount || { value: 0, type: 'fixed', amount: 0 };

    return parsed;
  } catch (e) {
    console.error('Failed to load last receipt:', e);
    return null;
  }
}
function prepareNextOrder() {
  newCustomer();
  loadMyDailySales();
}
async function loadMyDailySales() {
  try {
    const res = await fetch('/api/stats/my-daily-sales', {
      headers: { 'Accept': 'application/json' }
    });

    const data = await res.json();

    if (!res.ok) {
      throw new Error(data.error || 'Failed to load sales');
    }

    const salesBox = document.getElementById('my-daily-revenue');
    const invoicesBox = document.getElementById('my-daily-invoices');

    if (salesBox) {
      salesBox.textContent = '$' + Number(data.revenue || 0).toFixed(2);
    }

    if (invoicesBox) {
      invoicesBox.textContent = String(Number(data.invoices || 0));
    }

  } catch (e) {
    console.error('loadMyDailySales error:', e);
  }
}
async function confirmOrder() {
  if (!sessionOpen) {
    alert('Open Day first');
    return;
  }

  if (confirmed || isSubmitting) return;

  if (cart.length === 0) {
    alert('Cart empty');
    return;
  }

  isSubmitting = true;
  setButtons();

  const items = cart.map(c => ({
    id: c.id,
    type: c.type,
    category: c.category,
    qty: c.qty,
    unitPriceCents: Math.round((Number(c.price || 0) * 100))
  }));

  const discount = getDiscountData();

  try {
    const createRes = await fetch('/api/orders', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        items,
        discountValue: discount.value,
        discountType: discount.type,
        discountAmount: discount.amount
      })
    });

    if (!createRes.ok) {
      alert('Create failed: ' + await createRes.text());
      return;
    }

    const confirmedOrder = await createRes.json();

    const savedCart = JSON.parse(JSON.stringify(cart));

    saveLastReceipt(savedCart, confirmedOrder, discount);

    const invoiceBadge = document.getElementById('invoice-number');
    if (invoiceBadge && confirmedOrder.invoiceNumber != null) {
      invoiceBadge.textContent = String(Number(confirmedOrder.invoiceNumber) + 1);
    }

    printReceipt(savedCart, confirmedOrder, discount);
    prepareNextOrder();

    showSuccess(
      'Order confirmed - Invoice #' +
      (confirmedOrder.invoiceNumber != null ? confirmedOrder.invoiceNumber : 'N/A')
    );

  } catch (e) {
    console.error(e);
    alert('Network error: ' + e.message);
  } finally {
    isSubmitting = false;
    setButtons();
  }
}
