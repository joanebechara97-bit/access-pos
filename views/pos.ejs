        <div>Invoice: <span class="right">${invoiceNo}</span></div>
        <div>Cashier: <span class="right">${cashierName}</span></div>
        <div>Date: <span class="right">${formatReceiptDate(now)}</span></div>
        <div>Time: <span class="right">${formatReceiptTime(now)}</span></div>

        <div class="line"></div>

        <table>
          <tbody>
            ${rows}
          </tbody>
        </table>

        <div class="line"></div>

        <table class="totals">
          <tr>
            <td>SUBTOTAL</td>
            <td style="text-align:right">$${subtotal.toFixed(2)}</td>
          </tr>
          ${discountRow}
          <tr>
            <td class="total-main">TOTAL</td>
            <td class="total-main" style="text-align:right">$${finalTotal.toFixed(2)}</td>
          </tr>
        </table>

        <div class="line"></div>

        <div class="center small">Thank you</div>
        <div class="center small">San Stephano Resort</div>
        <div class="center small">Batroun - North Lebanon</div>
        <div class="qr-wrap">
          <img src="${instaQR}" alt="Instagram QR" />
        </div>
        <div class="center small">Print #${printCount}</div>

        <div class="cut-space"></div>
      </body>
    </html>
  `, onAfterPrint);
}
function newCustomer() {

  cart = [];
  confirmed = false;

  const discountValue = document.getElementById('discount-value');
  const discountType = document.getElementById('discount-type');

  if (discountValue) discountValue.value = 0;
  if (discountType) discountType.value = 'fixed';

  updateDiscountSymbol();
  renderCart();
  setButtons();
}
    document.addEventListener('keydown', (e) => {
      const tag = (document.activeElement && document.activeElement.tagName ? document.activeElement.tagName : '').toLowerCase();
      const isTyping = tag === 'input' || tag === 'textarea' || tag === 'select';

      if (isTyping) return;

      if (e.key === 'F1' || e.key === 'Enter') {
        e.preventDefault();
        const confirmBtn = document.getElementById('confirm-btn');
        if (confirmBtn && !confirmBtn.disabled) {
          confirmOrder();
        }
      }

      if (e.key === 'F2') {
        e.preventDefault();
        newCustomer();
      }

      if (['1', '2', '3', '4'].includes(e.key)) {
        e.preventDefault();
        const idx = Number(e.key) - 1;
        const btns = document.querySelectorAll('.pos-item-btn');
        if (btns[idx]) {
          btns[idx].click();
        }
      }

      if (e.key === 'Delete') {
        e.preventDefault();
        if (cart.length > 0) {
          cart.pop();
          renderCart();
        }
      }
    });

    const discountValueEl = document.getElementById('discount-value');
    const discountTypeEl = document.getElementById('discount-type');

    if (discountValueEl) {
      discountValueEl.addEventListener('input', renderCart);
    }

    if (discountTypeEl) {
      discountTypeEl.addEventListener('change', function () {
        updateDiscountSymbol();
        renderCart();
      });
    }

renderCart();
loadMyDailySales();
updateDiscountSymbol();
updateSessionButtons();
loadLastReceipt();
updateShiftTimer();
setInterval(updateShiftTimer, 60000);
  </script>
  <%- include('partials/footer') %>

  <script>
    const reportsToggle = document.getElementById('reportsToggle');
    const reportsMenu = document.getElementById('reportsMenu');

    if (reportsToggle && reportsMenu) {
      reportsToggle.addEventListener('click', function (e) {
        e.stopPropagation();
        reportsMenu.classList.toggle('show');
      });

      document.addEventListener('click', function () {
        reportsMenu.classList.remove('show');
      });
    }
  </script>
</body>
</html>
