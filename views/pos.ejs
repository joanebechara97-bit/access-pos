<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>POS</title>
  <link rel="stylesheet" href="/style.css" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <style>
.site{
  max-width:min(1480px, 100%);
  margin:0 auto;
  padding:18px;
}

.dropdown {
  position: relative;
  display: inline-block;
  z-index: 1000;
}

.dropdown-toggle {
  position: relative;
  z-index: 1001;
  cursor: pointer;
}

.dropdown-menu {
  display: none;
  position: absolute;
  top: 110%;
  right: 0;
  min-width: 180px;
  background: #fff;
  border: 1px solid #e5eaf2;
  border-radius: 12px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  padding: 8px;
  z-index: 1002;
}

.dropdown-menu.show {
  display: block;
}

.dropdown-menu a {
  display: block;
  padding: 10px 12px;
  text-decoration: none;
  color: #0f172a;
  border-radius: 8px;
}

.dropdown-menu a:hover {
  background: #f3f6fb;
}

    .btn.logout-btn{
      padding:10px 14px;
      border-radius:12px;
      border:none;
      font-weight:800;
      background:#fff;
      cursor:pointer;
      text-decoration:none;
      color:#0f172a;
      box-shadow:0 8px 22px rgba(15,23,42,.08);
    }

    .pos-shell{
      display:grid;
      grid-template-columns:1fr;
      gap:18px;
      transition:opacity .15s ease;
      overflow:hidden;
    }

    .pos-header-bar,
    .pos-info-bar,
    .pos-left-panel,
    .pos-right-panel{
      background:#fff;
      border:none;
      border-radius:20px;
      box-shadow:0 8px 24px rgba(15,23,42,.06);
    }

    .pos-header-bar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:20px;
      padding:18px 20px;
    }

    .header-left{
      display:flex;
      align-items:center;
      gap:16px;
      min-width:0;
    }

    .header-logo{
      width:70px;
      height:auto;
      object-fit:contain;
    }

    .header-title{
      font-size:20px;
      font-weight:800;
      color:#0f172a;
      line-height:1.15;
    }

    .header-actions{
      display:flex;
      align-items:center;
      gap:10px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .pos-info-bar{
      display:grid;
      grid-template-columns:repeat(6, minmax(140px, 1fr));
      gap:12px;
      padding:16px;
    }

    .info-card{
      border:none;
      border-radius:18px;
      background:#f8fafc;
      padding:14px 16px;
      min-height:76px;
      display:flex;
      flex-direction:column;
      justify-content:center;
      box-shadow:inset 0 0 0 1px rgba(15,23,42,.04);
    }

    .info-label{
      font-size:12px;
      color:#64748b;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.4px;
      margin-bottom:4px;
    }

    .info-value{
      font-size:18px;
      font-weight:800;
      color:#0f172a;
      line-height:1.2;
      overflow-wrap:anywhere;
      word-break:break-word;
    }

    .cashier-name{
      display:block;
      max-width:100%;
      font-size:clamp(13px, 1.4vw, 18px);
    }

    .info-card.cashier{ background:#ecfeff; }
    .info-card.invoice{ background:#fef9c3; }
    .info-card.items{ background:#eef2ff; }
    .info-card.total{ background:#ecfdf5; }

    .pos-main-grid{
      display:grid;
      grid-template-columns:minmax(280px, .95fr) minmax(360px, 1.05fr);
      gap:18px;
      align-items:start;
    }

    .pos-left-panel,
    .pos-right-panel{
      padding:16px;
      min-width:0;
    }

    .pos-footer-actions{
  display:grid;
  grid-template-columns:repeat(4, minmax(0, 1fr));
  gap:14px;
}

    .pos-footer-actions button{
      width:100%;
      padding:15px 18px;
      border-radius:16px;
      font-weight:800;
      border:none;
      box-shadow:0 8px 22px rgba(15,23,42,.08);
      cursor:pointer;
      transition:transform .15s ease, box-shadow .15s ease, opacity .15s ease, background .15s ease;
    }

    .pos-footer-actions button:not(:disabled):hover{
      transform:translateY(-1px);
      box-shadow:0 12px 26px rgba(15,23,42,.11);
    }

    #confirm-btn{
      background:#111827;
      color:#fff;
    }

    #confirm-btn:disabled,
    #new-btn:disabled{
      opacity:.5;
      cursor:not-allowed;
    }

    body.is-submitting .pos-item-btn,
    body.is-submitting #cart-table input,
    body.is-submitting .discount-box input,
    body.is-submitting .discount-box select,
    body.is-submitting .quick-discounts button{
      pointer-events:none;
      opacity:.65;
    }

    #new-btn{
      background:#fff;
      color:#111827;
    }

    .buttons{
      display:grid;
      grid-template-columns:repeat(2, minmax(0,1fr));
      gap:12px;
    }

    .buttons button{
      padding:14px;
      border-radius:16px;
      border:none;
      background:#fff;
      cursor:pointer;
      font-weight:700;
      text-align:left;
      box-shadow:0 6px 18px rgba(15,23,42,.06);
      transition:transform .15s ease, box-shadow .15s ease, background .15s ease;
    }

    .buttons button:hover{
      background:#f8fafc;
      transform:translateY(-1px);
      box-shadow:0 10px 24px rgba(15,23,42,.09);
    }

    .btn-title{
      display:block;
      font-size:15px;
      font-weight:800;
      color:#0f172a;
    }

    .btn-type{
      display:block;
      font-size:12px;
      color:#64748b;
      margin-top:2px;
    }

    .btn-price{
      display:block;
      font-size:14px;
      color:#111827;
      margin-top:6px;
    }

    .empty-items{
      color:#64748b;
      font-size:14px;
      padding:10px 0;
    }

    #cart-table{
      width:100%;
      min-width:560px;
      border-collapse:separate;
      border-spacing:0 8px;
    }

    .cart-scroll{
      width:100%;
      overflow-x:auto;
      -webkit-overflow-scrolling:touch;
    }

    #cart-table thead th{
      font-size:14px;
      color:#475569;
      text-align:left;
      padding:0 10px 6px;
    }

    #cart-table tbody tr{
      background:#f8fafc;
    }

    #cart-table tbody td{
      padding:12px 10px;
      vertical-align:middle;
    }

    #cart-table tbody tr td:first-child{
      border-top-left-radius:12px;
      border-bottom-left-radius:12px;
    }

    #cart-table tbody tr td:last-child{
      border-top-right-radius:12px;
      border-bottom-right-radius:12px;
    }

    #cart-table tfoot td{
      padding:10px;
      font-weight:800;
    }

    #cart-table input[type="number"]{
      width:60px;
      border:none;
      border-radius:10px;
      background:#fff;
      box-shadow:inset 0 0 0 1px rgba(15,23,42,.08);
      padding:8px 10px;
      font-weight:700;
    }

    #cart-table button{
      border:none;
      border-radius:10px;
      background:#0f3f87;
      color:#fff;
      padding:8px 12px;
      font-weight:700;
      cursor:pointer;
    }

.discount-box{
  margin-top:14px;
  padding:16px;
  border-radius:18px;
  background:#f8fafc;
  box-shadow:inset 0 0 0 1px rgba(15,23,42,.05);
}

.discount-box label{
  display:block;
  margin-bottom:10px;
  font-size:13px;
  font-weight:700;
  color:#475569;
}

.discount-top{
  display:grid;
  grid-template-columns:1fr 86px;
  gap:10px;
  align-items:center;
}

.discount-input-wrap{
  position:relative;
  width:100%;
}

.discount-input-wrap input{
  width:100%;
  height:44px;
  border:none;
  border-radius:12px;
  padding:0 38px 0 14px;
  background:#fff;
  box-shadow:inset 0 0 0 1px rgba(15,23,42,.08);
  font-weight:800;
  font-size:15px;
  color:#0f172a;
  box-sizing:border-box;
}

.discount-row select,
.discount-top select{
  width:100%;
  height:44px;
  border:none;
  border-radius:12px;
  padding:0 12px;
  background:#fff;
  box-shadow:inset 0 0 0 1px rgba(15,23,42,.08);
  font-weight:800;
  font-size:14px;
  color:#0f172a;
}

.discount-symbol{
  position:absolute;
  right:14px;
  top:50%;
  transform:translateY(-50%);
  font-weight:800;
  color:#475569;
  pointer-events:none;
}

.quick-discounts{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-top:10px;
}

.quick-discounts button{
  height:40px;
  border:none;
  border-radius:12px;
  background:#fff;
  color:#0f172a;
  box-shadow:inset 0 0 0 1px rgba(15,23,42,.08);
  font-weight:800;
  font-size:14px;
  cursor:pointer;
}

.quick-discounts button:hover{
  background:#f1f5f9;
}

.quick-discounts button:active{
  transform:scale(.98);
}

.quick-discounts button.active{
  background:#0f172a;
  color:#fff;
}

.discount-summary{
  margin-top:14px;
  padding-top:12px;
  border-top:1px solid rgba(15,23,42,.08);
}

.summary-line{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:7px 0;
  color:#334155;
  font-size:14px;
}

.summary-line strong{
  font-weight:800;
  color:#0f172a;
  min-width:90px;
  text-align:right;
}

.summary-line.final{
  margin-top:2px;
  font-size:16px;
  font-weight:800;
}

.summary-line.final strong{
  font-size:16px;
}

    .success-banner{
      position:fixed;
      top:24px;
      left:50%;
      transform:translateX(-50%) translateY(-10px);
      background:#111827;
      color:#fff;
      padding:12px 18px;
      border-radius:999px;
      font-weight:700;
      font-size:14px;
      box-shadow:0 12px 30px rgba(0,0,0,.18);
      opacity:0;
      pointer-events:none;
      transition:opacity .25s ease, transform .25s ease;
      z-index:9999;
    }

    .success-banner.show{
      opacity:1;
      transform:translateX(-50%) translateY(0);
    }

    @media (max-width: 1200px){
      .pos-info-bar{
        grid-template-columns:repeat(4, minmax(130px, 1fr));
      }

      .pos-footer-actions{
        grid-template-columns:repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 900px){
      .pos-header-bar{
        flex-direction:column;
        align-items:stretch;
      }

      .header-actions{
        justify-content:flex-start;
      }

      .pos-main-grid{
        grid-template-columns:1fr;
      }

      .buttons{
        grid-template-columns:1fr;
      }

      .pos-info-bar{
        grid-template-columns:repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px){
      .pos-header-bar,
      .pos-info-bar,
      .pos-left-panel,
      .pos-right-panel{
        border-radius:14px;
      }

      .header-left{
        align-items:flex-start;
      }

      .header-logo{
        width:54px;
      }

      .header-actions{
        display:grid;
        grid-template-columns:1fr 1fr;
        width:100%;
      }

      .header-actions .btn,
      .header-actions button,
      .dropdown{
        width:100%;
      }

      .pos-info-bar{
        grid-template-columns:1fr;
      }

      .pos-footer-actions{
        grid-template-columns:1fr;
      }
    }
  </style>
</head>

<body>
  <div class="site">
    <div id="success-banner" class="success-banner"></div>

    <div class="card pos-shell">
      <div class="pos-header-bar">
        <div class="header-left">
          <img src="/assets/logo-ss-png.png" alt="San Stephano" class="header-logo">
          <div class="header-title">San Stephano Daily Access</div>
        </div>

       <div class="header-actions">

<button id="open-day-btn" onclick="openDay()" class="btn logout-btn">🟢 Open Day</button>
<button id="close-day-btn" onclick="closeDay()" class="btn logout-btn">🔴 Close Day</button>

<div class="dropdown" id="reportsDropdown">
  <button type="button" class="dropdown-toggle" id="reportsToggle">
    📊 Reports ▾
  </button>

  <div class="dropdown-menu" id="reportsMenu">
    <a href="/reports/daily">Daily report</a>

    <% if (user && user.perms && user.perms.canViewMonthlyReport) { %>
      <a href="/reports/monthly">Monthly report</a>
    <% } %>

<% if (user && user.perms && user.perms.canRefundInvoice) { %>
        <a href="/reports/voided">Voided invoices</a>
    <% } %>
  </div>
</div>

<% if (user && user.perms && user.perms.canRefundInvoice) { %>
              <a class="btn logout-btn" href="/refund">Void / Refund</a>
          <% } %>

          <% if (user && user.perms && user.perms.canManageSettings) { %>
  <a class="btn logout-btn" href="/admin">Admin</a>
<% } %>

          <a class="btn logout-btn" href="/logout">Log out</a>
        </div>
      </div>

      <div class="pos-info-bar">
        <div class="info-card cashier">
          <div class="info-label">Cashier</div>
          <div class="info-value cashier-name">
            <%= (user && (user.username || user.name || user.email)) ? (user.username || user.name || user.email) : 'Unknown' %>
          </div>
        </div>

        <div class="info-card invoice">
          <div class="info-label">Invoice Number</div>
          <div class="info-value">
            #<span id="invoice-number"><%= typeof nextInvoice !== 'undefined' && nextInvoice !== null ? nextInvoice : 'N/A' %></span>
          </div>
        </div>

        <div class="info-card items">
          <div class="info-label">Items</div>
          <div class="info-value" id="items-count">0</div>
        </div>

        <div class="info-card total">
          <div class="info-label">Current Total</div>
          <div class="info-value" id="top-grand-total">$0.00</div>
        </div>

        <div class="info-card">
          <div class="info-label">My Sales Today</div>
          <div class="info-value" id="my-daily-revenue">$0.00</div>
        </div>
<div class="info-card">
  <div class="info-label">Shift Started</div>
  <div class="info-value" id="shift-started-value">
    <% if (sessionData && sessionData.openedAt) { %>
      <%= new Date(sessionData.openedAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
    <% } else { %>
      --
    <% } %>
  </div>
</div>

<div class="info-card">
  <div class="info-label">Shift Duration</div>
  <div class="info-value" id="shift-duration-value">--</div>
</div>
        <div class="info-card">
          <div class="info-label">My Invoices Today</div>
          <div class="info-value" id="my-daily-invoices">0</div>
        </div>
      </div>

      <div class="pos-main-grid">
        <div class="pos-left-panel">
          <h3>Order Options</h3>

          <% if (items && items.length) { %>
            <div class="buttons">
              <% items.forEach((item, index) => { %>
                <button
                  type="button"
                  class="pos-item-btn"
                  data-id="<%= item.id %>"
                  data-name="<%= item.name %>"
                  data-type="<%= item.type %>"
                  data-price="<%= Number(item.price) %>"
                  data-index="<%= index %>"
                  onclick="addToCart(this.dataset.id, this.dataset.name, this.dataset.type, Number(this.dataset.price))"
                >
                  <span class="btn-title">[<%= index + 1 %>] <%= item.name %></span>
                  <span class="btn-type"><%= item.type %></span>
                  <span class="btn-price">$<%= Number(item.price).toFixed(2) %></span>
                </button>
              <% }) %>
            </div>
          <% } else { %>
            <div class="empty-items">No active items found. Add items from Admin → Items & Prices.</div>
          <% } %>
        </div>

        <div class="pos-right-panel">
          <h3>Current Order</h3>

          <div class="cart-scroll">
          <table id="cart-table">
            <thead>
              <tr>
                <th>Category</th>
                <th>Qty</th>
                <th>Price</th>
                <th>Total</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody></tbody>
            <tfoot>
              <tr>
                <td colspan="3" style="text-align:right">Grand Total</td>
                <td id="grand-total">$0.00</td>
                <td></td>
              </tr>
            </tfoot>
          </table>
          </div>

<% if (user && user.perms && user.perms.canApplyDiscount) { %>
          <div class="discount-box">
  <label for="discount-value">Discount</label>

  <div class="discount-top">
    <div class="discount-input-wrap">
      <input
        id="discount-value"
        type="number"
        min="0"
        value="0"
        step="0.01"
        placeholder="0"
      >
      <span id="discount-symbol" class="discount-symbol">$</span>
    </div>

    <select id="discount-type">
      <option value="fixed">$</option>
      <option value="percent">%</option>
    </select>
  </div>
<div class="quick-discounts">
  <button type="button" onclick="applyQuickDiscount(10)">10%</button>
  <button type="button" onclick="applyQuickDiscount(50)">50%</button>
</div>

  <div class="discount-summary">
    <div class="summary-line">
      <span>Subtotal</span>
      <strong id="subtotal-amount">$0.00</strong>
    </div>
    <div class="summary-line">
      <span>Discount</span>
      <strong id="discount-amount">-$0.00</strong>
    </div>
    <div class="summary-line final">
      <span>Final Total</span>
      <strong id="final-total-amount">$0.00</strong>
    </div>
  </div>
</div>
          <% } %>
        </div>
      </div>

<div class="pos-footer-actions">
  <button id="confirm-btn" onclick="confirmOrder()">✔ Confirm Order</button>
  <button onclick="clearCart()">🗑 Clear</button>
  <button id="new-btn" onclick="newCustomer()">↺ New Customer</button>
  <button id="reprint-btn" onclick="reprintLastReceipt()">🧾 Reprint Last</button>
</div>
    </div>
  </div>
<div id="pos-config" data-session-open="<%= (typeof sessionOpen !== 'undefined' && sessionOpen) ? 'true' : 'false' %>" hidden></div>
<script>
let lastConfirmedOrder = null;
let lastConfirmedDiscount = null;
let lastConfirmedCart = null;

const LAST_RECEIPT_KEY = 'last_confirmed_receipt';
  let cart = [];
  let confirmed = false;
  let isSubmitting = false;
const posConfig = document.getElementById('pos-config');
let sessionOpen = posConfig && posConfig.dataset.sessionOpen === 'true';
const POS_TAB_KEY = 'cabine_pos_tab_open';

if (localStorage.getItem(POS_TAB_KEY) === 'true') {
  alert('POS is already open in another tab.');
}

localStorage.setItem(POS_TAB_KEY, 'true');

window.addEventListener('beforeunload', function () {
  localStorage.removeItem(POS_TAB_KEY);
});

  function setButtons() {
    const confirmBtn = document.getElementById('confirm-btn');
    const newBtn = document.getElementById('new-btn');

    document.body.classList.toggle('is-submitting', isSubmitting);

    if (confirmBtn) {
      if (!confirmBtn.dataset.defaultLabel) {
        confirmBtn.dataset.defaultLabel = confirmBtn.textContent;
      }

      confirmBtn.disabled = !sessionOpen || confirmed || isSubmitting || cart.length === 0;
      confirmBtn.textContent = isSubmitting ? 'Confirming...' : confirmBtn.dataset.defaultLabel;
    }

    if (newBtn) newBtn.disabled = !sessionOpen || !confirmed;
  }


  function prettyName(name) {
    return String(name || '').replaceAll('_', ' ');
  }

  function showSuccess(message) {
    const banner = document.getElementById('success-banner');
    if (!banner) return;

    banner.textContent = message;
    banner.classList.add('show');

    clearTimeout(window.__successBannerTimer);
    window.__successBannerTimer = setTimeout(() => {
      banner.classList.remove('show');
    }, 1800);
  }

    function getSubtotal(items) {
      return (items || []).reduce((sum, it) => {
        const qty = Number(it.qty || 0);
        const price = Number(it.price || 0);
        return sum + (qty * price);
      }, 0);
    }

    function getDiscountData() {
      const valueEl = document.getElementById('discount-value');
      const typeEl = document.getElementById('discount-type');

      if (!valueEl || !typeEl) {
        return { value: 0, type: 'fixed', amount: 0 };
      }

      const value = Math.max(0, Number(valueEl.value || 0));
      const type = typeEl.value === 'percent' ? 'percent' : 'fixed';
      const subtotal = getSubtotal(cart);

      let amount = 0;
      if (type === 'percent') {
        amount = subtotal * (value / 100);
      } else {
        amount = value;
      }

      if (amount < 0) amount = 0;
      if (amount > subtotal) amount = subtotal;

      return { value, type, amount };
    }

    function getDiscountAmount(subtotal, discount) {
      if (!discount) return 0;

      const type = discount.type || 'fixed';
      const rawAmount = Number(discount.amount || 0);

      let discountAmount = 0;

      if (type === 'percent') {
        discountAmount = subtotal * (rawAmount / 100);
      } else {
        discountAmount = rawAmount;
      }

      if (discountAmount < 0) discountAmount = 0;
      if (discountAmount > subtotal) discountAmount = subtotal;

      return discountAmount;
    }

    function updateDiscountSymbol() {
      const typeEl = document.getElementById('discount-type');
      const symbolEl = document.getElementById('discount-symbol');

      if (!typeEl || !symbolEl) return;
      symbolEl.textContent = typeEl.value === 'percent' ? '%' : '$';
    }
function clearCart(){
  if (confirmed || isSubmitting) return;
  cart = [];
  renderCart();
}
function applyQuickDiscount(percent){

  if (confirmed || isSubmitting) return;

  const value = document.getElementById('discount-value');
  const type = document.getElementById('discount-type');

  if (!value || !type) return;

  type.value = 'percent';
  value.value = percent;

  document.querySelectorAll('.quick-discounts button')
    .forEach(b => b.classList.remove('active'));

  const btn = [...document.querySelectorAll('.quick-discounts button')]
    .find(b => b.textContent === percent + '%');

  if (btn) btn.classList.add('active');

  updateDiscountSymbol();
  renderCart();
}
function updateSessionButtons() {
  const openBtn = document.getElementById('open-day-btn');
  const closeBtn = document.getElementById('close-day-btn');

  if (openBtn) openBtn.style.display = sessionOpen ? 'none' : 'inline-flex';
  if (closeBtn) closeBtn.style.display = sessionOpen ? 'inline-flex' : 'none';
}
function addToCart(id, category, type, price) {
  if (!sessionOpen) {
    alert('Open Day first');
    return;
  }

  if (confirmed || isSubmitting) return;

  const found = cart.find(c => c.id === id);
  if (found) {
    found.qty += 1;
  } else {
    cart.push({
      id,
      category,
      type,
      qty: 1,
      price: Number(price) || 0
    });
  }

  renderCart();
}

    function renderCart() {
      const tbody = document.querySelector('#cart-table tbody');
      if (!tbody) return;

      tbody.innerHTML = '';

      let subtotal = 0;

      cart.forEach((item, idx) => {
        const qty = Math.max(1, Number(item.qty || 1));
        const price = Number(item.price || 0);
        const total = qty * price;

        subtotal += total;

        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${prettyName(item.category)}</td>
          <td>
            <input
              type="number"
              min="1"
              value="${qty}"
              onchange="updateQty(${idx}, this.value)"
              ${confirmed ? 'disabled' : ''}
            >
          </td>
          <td>$${price.toFixed(2)}</td>
          <td>$${total.toFixed(2)}</td>
          <td>
            <button type="button" onclick="deleteItem(${idx})" ${confirmed ? 'disabled' : ''}>Delete</button>
          </td>
        `;
        tbody.appendChild(tr);
      });

      const discount = getDiscountData();
      const finalTotal = Math.max(0, subtotal - discount.amount);

      const grandEl = document.getElementById('grand-total');
      const itemsEl = document.getElementById('items-count');
      const totalEl = document.getElementById('top-grand-total');
      const subtotalEl = document.getElementById('subtotal-amount');
      const discountEl = document.getElementById('discount-amount');
      const finalTotalEl = document.getElementById('final-total-amount');

      const totalQty = cart.reduce((sum, item) => sum + Math.max(1, Number(item.qty || 1)), 0);

      if (grandEl) grandEl.textContent = '$' + finalTotal.toFixed(2);
      if (itemsEl) itemsEl.textContent = String(totalQty);
      if (totalEl) totalEl.textContent = '$' + finalTotal.toFixed(2);
      if (subtotalEl) subtotalEl.textContent = '$' + subtotal.toFixed(2);
      if (discountEl) discountEl.textContent = '-$' + Number(discount.amount || 0).toFixed(2);
      if (finalTotalEl) finalTotalEl.textContent = '$' + finalTotal.toFixed(2);

      setButtons();
    }

    function updateQty(i, v) {
      if (confirmed || isSubmitting) return;

      const qty = Math.max(1, parseInt(v, 10) || 1);
      cart[i].qty = qty;
      renderCart();
    }

    function deleteItem(i) {
      if (confirmed || isSubmitting) return;

      cart.splice(i, 1);
      renderCart();
    }
async function openDay() {
  try {
    const res = await fetch('/api/session/open', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });

    const data = await res.json().catch(() => ({}));

    if (!res.ok) {
      alert(data.error || ('Failed to open day (' + res.status + ')'));
      return;
    }

    sessionOpen = true;
    setButtons();
    updateSessionButtons();
    showSuccess('Day opened');
  } catch (e) {
    console.error(e);
    alert('Failed to open day');
  }
}
function updateShiftTimer() {
  const durationEl = document.getElementById('shift-duration-value');
  if (!durationEl) return;

  const rawEl = document.getElementById('shift-opened-at-data');
  if (!rawEl) {
    durationEl.textContent = '--';
    return;
  }

  const openedAtRaw = JSON.parse(rawEl.textContent);

  if (!openedAtRaw) {
    durationEl.textContent = '--';
    return;
  }

  const openedAt = new Date(openedAtRaw);
  if (isNaN(openedAt.getTime())) {
    durationEl.textContent = '--';
    return;
  }

  const now = new Date();
  const diffMs = Math.max(0, now - openedAt);

  const totalMinutes = Math.floor(diffMs / 60000);
  const hours = Math.floor(totalMinutes / 60);
  const minutes = totalMinutes % 60;

  durationEl.textContent = `${hours}h ${minutes}m`;
}
const RECEIPT_PRINT_COUNT_KEY = 'cabine_pos_receipt_print_counts_v1';
const RECEIPT_TIME_ZONE = '<%= businessTimeZone || "Asia/Beirut" %>';

function formatReceiptDate(dateValue) {
  return new Intl.DateTimeFormat('en-GB', {
    timeZone: RECEIPT_TIME_ZONE,
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(new Date(dateValue));
}

function formatReceiptTime(dateValue) {
  return new Intl.DateTimeFormat('en-GB', {
    timeZone: RECEIPT_TIME_ZONE,
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: true
  }).format(new Date(dateValue));
}

function nextReceiptPrintCount(invoiceNo, kind) {
  try {
    const raw = localStorage.getItem(RECEIPT_PRINT_COUNT_KEY);
    const map = raw ? JSON.parse(raw) : {};
    const key = `${kind || 'sale'}:${invoiceNo || 'N/A'}`;
    const next = Number(map[key] || 0) + 1;
    map[key] = next;
    localStorage.setItem(RECEIPT_PRINT_COUNT_KEY, JSON.stringify(map));
    return next;
  } catch (err) {
    console.error('Failed to store receipt print count:', err);
    return 1;
  }
}

function printHtmlInHiddenFrame(title, html, onAfterPrint) {
  const frame = document.createElement('iframe');
  frame.setAttribute('title', title);
  frame.style.position = 'fixed';
  frame.style.width = '0';
  frame.style.height = '0';
  frame.style.border = '0';
  frame.style.opacity = '0';
  frame.style.pointerEvents = 'none';
  frame.style.right = '0';
  frame.style.bottom = '0';
  document.body.appendChild(frame);

  const frameWindow = frame.contentWindow;
  const frameDocument = frameWindow.document;

  frameDocument.open();
  frameDocument.write(html);
  frameDocument.close();

  let afterPrintHandled = false;
  const finishAfterPrint = function () {
    if (afterPrintHandled) return;
    afterPrintHandled = true;
    if (typeof onAfterPrint === 'function') {
      onAfterPrint();
    }
  };

  setTimeout(function () {
    try {
      if (frameWindow && typeof frameWindow.addEventListener === 'function') {
        frameWindow.addEventListener('afterprint', finishAfterPrint, { once: true });
      }
      frameWindow.focus();
      frameWindow.print();
    } finally {
      setTimeout(finishAfterPrint, 1200);
      setTimeout(function () {
        frame.remove();
      }, 1500);
    }
  }, 500);
}

